@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing

<div class="page">
    <nav class="navbar navbar-expand navbar-dark bg-dark fixed-top"> @* Changed navbar-expand-lg to navbar-expand *@
        <div class="container-fluid">
            <a class="navbar-brand" href="/"></a>
            <div class="collapse navbar-collapse show">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 flex-row flex-nowrap"> @* Added flex-row flex-nowrap *@
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                            <span aria-hidden="true">💰</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/pomodoro">
                            <span aria-hidden="true">🍅</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/temptations">
                            <span aria-hidden="true">😈</span>
                        </NavLink>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    // showSidebar and ToggleSidebar removed
}

<style>
    /* Removed all sidebar-related styles */

    .content {
        padding-top: 70px; /* Adjust content padding to account for fixed top navbar height */
    }

    .navbar-brand {
        font-weight: bold;
    }

    .navbar-nav .nav-link {
        font-size: 1.5rem; /* Larger emojis */
        padding: 0.5rem 0.75rem;
    }

    .navbar-nav .nav-link.active {
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 5px;
    }
</style>