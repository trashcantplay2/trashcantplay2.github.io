@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing

<div class="page">
    <nav class="navbar navbar-expand navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">My Apps</a> @* App name changed *@
            <div class="collapse navbar-collapse show">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 flex-row flex-nowrap">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                            <span aria-hidden="true">💰</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/temptations">
                            <span aria-hidden="true">😈</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/finch">
                            <span aria-hidden="true">🐦</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/pomodoro">
                            <span aria-hidden="true">🍅</span>
                        </NavLink>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    // No code needed here for this layout
}

<style>
    .content {
        padding-top: 70px;
    }

    .navbar-brand {
        font-weight: bold;
    }

    .navbar-nav .nav-link {
        font-size: 1.5rem;
        padding: 0.5rem 0.75rem;
    }

    .navbar-nav .nav-link.active {
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 5px;
    }
</style>
