@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing

<div class="page">
    <div class="sidebar">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark flex-column align-items-stretch">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">My Forfeit</a>
                <div class="collapse navbar-collapse show">
                    <ul class="navbar-nav flex-column">
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                                <span class="oi oi-list-rich" aria-hidden="true"></span> Contracts
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/pomodoro">
                                <span class="oi oi-timer" aria-hidden="true"></span> Pomodoro
                            </NavLink>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    .sidebar {
        width: 200px;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        background-color: #343a40; /* Dark background for sidebar */
        padding-top: 1rem;
    }

    .sidebar .navbar-brand {
        color: white;
        padding-left: 1rem;
        padding-right: 1rem;
        margin-bottom: 1rem;
    }

    .sidebar .nav-link {
        color: rgba(255, 255, 255, 0.75);
        padding: 0.5rem 1rem;
    }

    .sidebar .nav-link.active {
        color: white;
        background-color: rgba(255, 255, 255, 0.1);
    }

    .sidebar .nav-link:hover {
        color: white;
        background-color: rgba(255, 255, 255, 0.05);
    }

    .content {
        margin-left: 200px; /* Offset content by sidebar width */
        padding-top: 1rem;
    }
</style>