@page "/temptations"
@inject ILocalStorageService LocalStorage

<PageTitle>Temptation Tracker</PageTitle>

<div class="container mt-4" style="max-width: 800px;">
    <h1 class="mb-4">😈 Temptation Tracker</h1>

    <div class="card p-4 mb-4 shadow-sm border-warning">
        @* "Record a temptation" text removed *@
        
        <div class="mb-3">
            @* "Common Temptations" text removed *@
            <div class="d-flex flex-wrap gap-2">
                @foreach (var temp in predefinedTemptations)
                {
                    <button class="btn btn-outline-warning" @onclick="() => RecordTemptation(temp)">@temp</button>
                }
            </div>
        </div>

        <div class="mb-3">
            @* "Or Add Your Own" text removed *@
            <div class="input-group">
                <input @bind="customTemptationName" class="form-control" placeholder="Add your own..." @onkeyup="HandleCustomInputKeyUp" />
                <button class="btn btn-warning" @onclick="AddCustomTemptation">Add</button>
            </div>
        </div>
    </div>

    <div class="card p-4 mb-4 shadow-sm border-secondary">
        <div class="d-flex justify-content-end align-items-center mb-2">
            @* "Your Temptation Log" text removed, Clear All button moved to the right *@
            <button class="btn btn-sm btn-outline-danger" @onclick="ClearAllTemptations">Clear All</button>
        </div>
        @if (trackedTemptations == null || !trackedTemptations.Any())
        {
            <p class="text-muted">No temptations logged yet.</p>
        }
        else
        {
            <ul class="list-group">
                @foreach (var temptation in trackedTemptations.OrderByDescending(t => t.Count).ThenBy(t => t.Name))
                {
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">@temptation.Name</h6>
                            <span class="badge bg-danger rounded-pill">@temptation.Count</span>
                        </div>
                        <ul class="list-unstyled mt-2">
                            @foreach (var occurrence in temptation.Occurrences.OrderByDescending(o => o.Timestamp))
                            {
                                <li class="d-flex justify-content-between align-items-center border-top pt-2 mt-2">
                                    <small class="text-muted">@occurrence.Timestamp.ToString("MMM dd, hh:mm tt")</small>
                                    <div class="input-group input-group-sm w-50">
                                        <input type="text" class="form-control" placeholder="Add a comment..." value="@occurrence.Comment" 
                                               @onchange="(e) => { occurrence.Comment = e.Value.ToString(); SaveTemptations(); }" />
                                    </div>
                                </li>
                            }
                        </ul>
                    </li>
                }
            </ul>
        }
    </div>
</div>

@code {
    private List<string> predefinedTemptations = new List<string>
    {
        "Reddit", "YouTube", "Eating/Buying Takeout", "Internet Browsing", "Breaking Fast"
    };

    private string customTemptationName = "";
    private List<TemptationEntry>? trackedTemptations;

    protected override async Task OnInitializedAsync()
    {
        trackedTemptations = await LocalStorage.GetItemAsync<List<TemptationEntry>>("trackedTemptations") ?? new List<TemptationEntry>();
    }

    private async Task RecordTemptation(string name)
    {
        var existing = trackedTemptations?.FirstOrDefault(t => t.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
        
        var now = DateTime.Now;
        var recordTime = new DateTime(now.Year, now.Month, now.Day, now.Hour, now.Minute, 0);

        if (existing != null)
        {
            existing.Occurrences.Add(new TemptationOccurrence { Timestamp = recordTime });
        }
        else
        {
            var newEntry = new TemptationEntry { Name = name };
            newEntry.Occurrences.Add(new TemptationOccurrence { Timestamp = recordTime });
            trackedTemptations?.Add(newEntry);
        }
        await SaveTemptations();
    }

    private async Task AddCustomTemptation()
    {
        if (!string.IsNullOrWhiteSpace(customTemptationName))
        {
            await RecordTemptation(customTemptationName.Trim());
            customTemptationName = "";
        }
    }

    private async Task HandleCustomInputKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddCustomTemptation();
        }
    }

    private async Task ClearAllTemptations()
    {
        trackedTemptations?.Clear();
        await SaveTemptations();
    }

    private async Task SaveTemptations()
    {
        await LocalStorage.SetItemAsync("trackedTemptations", trackedTemptations);
    }
}
