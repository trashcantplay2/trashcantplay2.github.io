@page "/"
@inject ILocalStorageService LocalStorage
@inject TelegramService Telegram

<PageTitle>My Forfeit</PageTitle>

<div class="container mt-4" style="max-width: 800px;">
    <h1 class="mb-4">💰 My Forfeit</h1>

    <div class="card p-3 mb-4 shadow-sm border-secondary">
        <h5 class="card-title">Telegram Settings</h5>
        <div class="row g-2">
            <div class="col-md-5">
                <input @bind="botToken" placeholder="Bot Token" class="form-control" type="password" />
            </div>
            <div class="col-md-5">
                <input @bind="chatId" placeholder="Chat ID" class="form-control" />
            </div>
            <div class="col-md-2">
                <button @onclick="SaveSettings" class="btn btn-secondary w-100">Save</button>
            </div>
        </div>
    </div>

    <div class="card p-4 mb-4 shadow-sm border-primary">
        <h5 class="card-title">Create New Contract</h5>
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">I will...</label>
                <input @bind="newTitle" placeholder="e.g. Go to the gym for 1 hour" class="form-control form-control-lg" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Deadline</label>
                <input @bind="newDeadline" type="datetime-local" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Stakes ($)</label>
                <div class="input-group">
                    <button class="btn btn-outline-secondary" @onclick="() => AdjustStakes(-5)">- $5</button>
                    <input type="number" class="form-control text-center" @bind="newStakes" readonly />
                    <button class="btn btn-outline-secondary" @onclick="() => AdjustStakes(5)">+ $5</button>
                </div>
            </div>
            <div class="col-12 mt-3">
                <button @onclick="AddContract" class="btn btn-primary btn-lg w-100">Commit to Contract</button>
            </div>
        </div>
    </div>

    <h4 class="mb-3">Active Contracts</h4>
    @if (contracts == null)
    {
        <div class="text-center p-5"><div class="spinner-border"></div></div>
    }
    else if (!contracts.Any())
    {
        <p class="text-muted">No contracts yet. Start by creating one above!</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var contract in contracts.OrderBy(c => c.Deadline))
            {
                <div class="list-group-item list-group-item-action @(IsViolated(contract) ? "list-group-item-danger" : (contract.IsCompleted ? "bg-light" : ""))">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div style="@(contract.IsCompleted ? "text-decoration: line-through; opacity: 0.6;" : "")">
                            <h5 class="mb-1">@contract.Title</h5>
                            <p class="mb-1">
                                <span class="badge bg-dark">$@contract.Stakes</span>
                                <span class="ms-2 text-muted">Deadline: @contract.Deadline.ToString("f")</span>
                            </p>
                        </div>
                        <div class="btn-group">
                            @if (!contract.IsCompleted)
                            {
                                <button @onclick="() => Complete(contract)" class="btn btn-success">Done</button>
                            }
                            <button @onclick="() => Remove(contract)" class="btn btn-outline-danger btn-sm">Delete</button>
                        </div>
                    </div>
                    @if (IsViolated(contract))
                    {
                        <div class="mt-2 small font-weight-bold text-danger">⚠️ VIOLATED: Pay up!</div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Contract>? contracts;
    private string newTitle = "";
    private DateTime newDeadline = DateTime.Now.AddDays(1);
    private int newStakes = 5;
    
    private string botToken = "";
    private string chatId = "";

    protected override async Task OnInitializedAsync()
    {
        contracts = await LocalStorage.GetItemAsync<List<Contract>>("contracts") ?? new List<Contract>();
        botToken = await LocalStorage.GetItemAsync<string>("tg_token") ?? "";
        chatId = await LocalStorage.GetItemAsync<string>("tg_chatid") ?? "";
        
        await CheckViolations();
    }

    private bool IsViolated(Contract c) => !c.IsCompleted && DateTime.Now > c.Deadline;

    private void AdjustStakes(int amount)
    {
        newStakes = Math.Max(5, newStakes + amount);
    }

    private async Task SaveSettings()
    {
        await LocalStorage.SetItemAsync("tg_token", botToken);
        await LocalStorage.SetItemAsync("tg_chatid", chatId);
    }

    private async Task AddContract()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) return;
        
        contracts?.Add(new Contract { 
            Title = newTitle, 
            Deadline = newDeadline, 
            Stakes = newStakes 
        });
        await Save();
        newTitle = "";
        newStakes = 5;
    }

    private async Task Complete(Contract c)
    {
        c.IsCompleted = true;
        await Save();
    }

    private async Task Remove(Contract c)
    {
        contracts?.Remove(c);
        await Save();
    }

    private async Task Save()
    {
        await LocalStorage.SetItemAsync("contracts", contracts);
    }

    private async Task CheckViolations()
    {
        if (contracts == null) return;

        bool changed = false;
        foreach (var c in contracts.Where(c => IsViolated(c) && !c.NotificationSent))
        {
            var message = $"💸 FORFEIT: You failed to: {c.Title}\n💰 Stakes: ${c.Stakes}\n📅 Deadline was: {c.Deadline:f}";
            var success = await Telegram.SendMessageAsync(botToken, chatId, message);
            
            if (success)
            {
                c.NotificationSent = true;
                changed = true;
            }
        }

        if (changed) await Save();
    }
}
