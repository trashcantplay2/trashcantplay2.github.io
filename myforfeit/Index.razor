@page "/"
@inject ILocalStorageService LocalStorage
@implements IDisposable

<PageTitle>My Forfeit</PageTitle>

<div class="container mt-4" style="max-width: 800px;">
    <h1 class="mb-4">💰 My Forfeit</h1>

    <div class="card p-3 mb-4 shadow-sm border-success text-center">
        <h5 class="card-title mb-0">Total: <span class="text-success">$@totalFulfilledStakes</span></h5>
    </div>

    <div class="card p-4 mb-4 shadow-sm border-primary">
        <h5 class="card-title">Create New Contract</h5>
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">I will...</label>
                <input @bind="newTitle" placeholder="e.g. Go to the gym for 1 hour" class="form-control form-control-lg" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Deadline</label>
                <input @bind="newDeadline" type="datetime-local" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Stakes ($)</label>
                <div class="input-group">
                    <button class="btn btn-outline-secondary" @onclick="() => AdjustStakes(-5)">- $5</button>
                    <input type="number" class="form-control text-center" @bind="newStakes" readonly />
                    <button class="btn btn-outline-secondary" @onclick="() => AdjustStakes(5)">+ $5</button>
                </div>
            </div>
            <div class="col-12 mt-3">
                <button @onclick="AddContract" class="btn btn-primary btn-lg w-100">Commit to Contract</button>
            </div>
        </div>
    </div>

    <h4 class="mb-3">Active Contracts</h4>
    @if (contracts == null)
    {
        <div class="text-center p-5"><div class="spinner-border"></div></div>
    }
    else if (!contracts.Any())
    {
        <p class="text-muted">No contracts yet. Start by creating one above!</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var contract in contracts.OrderBy(c => c.Deadline))
            {
                <div class="list-group-item list-group-item-action @(IsViolated(contract) ? "list-group-item-danger" : (contract.IsCompleted ? "bg-light" : ""))">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div style="@(contract.IsCompleted ? "text-decoration: line-through; opacity: 0.6;" : "")">
                            <h5 class="mb-1 d-inline-block">@contract.Title</h5>
                            @if (!contract.IsCompleted)
                            {
                                <span class="ms-2 badge @(GetTimeRemaining(contract.Deadline).TotalSeconds <= 0 ? "bg-danger" : "bg-info")">
                                    @FormatTimeRemaining(contract.Deadline)
                                </span>
                            }
                            <p class="mb-1">
                                <span class="badge bg-dark">$@contract.Stakes</span>
                                <span class="ms-2 text-muted">Deadline: @contract.Deadline.ToString("MMM dd, HH:mm")</span> @* Changed format to remove year *@
                            </p>
                        </div>
                        <div class="btn-group">
                            @if (!contract.IsCompleted)
                            {
                                <button @onclick="() => Complete(contract)" class="btn btn-success">Done</button>
                            }
                            <button @onclick="() => Remove(contract)" class="btn btn-outline-danger btn-sm">Delete</button>
                        </div>
                    </div>
                    @if (IsViolated(contract))
                    {
                        <div class="mt-2 small font-weight-bold text-danger">⚠️ VIOLATED: Pay up!</div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Contract>? contracts;
    private string newTitle = "";
    private DateTime newDeadline = DateTime.Now.AddDays(1);
    private int newStakes = 5;
    private int totalFulfilledStakes = 0; // New property for total fulfilled stakes

    private System.Timers.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        contracts = await LocalStorage.GetItemAsync<List<Contract>>("contracts") ?? new List<Contract>();
        
        await CheckViolations();
        CalculateTotalFulfilledStakes(); // Calculate on initialization

        _timer = new System.Timers.Timer(1000); // Update every 1 second
        _timer.Elapsed += async (sender, e) => await InvokeAsync(StateHasChanged);
        _timer.Start();
    }

    private bool IsViolated(Contract c) => !c.IsCompleted && DateTime.Now > c.Deadline;

    private void AdjustStakes(int amount)
    {
        newStakes = Math.Max(5, newStakes + amount);
    }

    private async Task AddContract()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) return;
        
        contracts?.Add(new Contract { 
            Title = newTitle, 
            Deadline = newDeadline, 
            Stakes = newStakes 
        });
        await Save();
        newTitle = "";
        newStakes = 5;
    }

    private async Task Complete(Contract c)
    {
        c.IsCompleted = true;
        await Save();
    }

    private async Task Remove(Contract c)
    {
        contracts?.Remove(c);
        await Save();
    }

    private async Task Save()
    {
        await LocalStorage.SetItemAsync("contracts", contracts);
        CalculateTotalFulfilledStakes(); // Recalculate after any save operation
    }

    private void CalculateTotalFulfilledStakes()
    {
        totalFulfilledStakes = contracts?.Where(c => c.IsCompleted).Sum(c => c.Stakes) ?? 0;
    }

    private async Task CheckViolations()
    {
        if (contracts == null) return;

        bool changed = false;
        foreach (var c in contracts.Where(c => IsViolated(c) && !c.NotificationSent))
        {
            // Removed Telegram message sending logic
            // For now, just mark as notified to prevent repeated "violations"
            c.NotificationSent = true; 
            changed = true;
        }

        if (changed) await Save();
    }

    private TimeSpan GetTimeRemaining(DateTime deadline)
    {
        return deadline - DateTime.Now;
    }

    private string FormatTimeRemaining(DateTime deadline)
    {
        var timeRemaining = GetTimeRemaining(deadline);

        if (timeRemaining.TotalSeconds <= 0)
        {
            return "OVERDUE";
        }

        if (timeRemaining.TotalDays >= 1)
        {
            return $"{timeRemaining.Days}d {timeRemaining.Hours}h {timeRemaining.Minutes}m";
        }
        else if (timeRemaining.TotalHours >= 1)
        {
            return $"{timeRemaining.Hours}h {timeRemaining.Minutes}m {timeRemaining.Seconds}s";
        }
        else if (timeRemaining.TotalMinutes >= 1)
        {
            return $"{timeRemaining.Minutes}m {timeRemaining.Seconds}s";
        }
        else
        {
            return $"{timeRemaining.Seconds}s";
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
