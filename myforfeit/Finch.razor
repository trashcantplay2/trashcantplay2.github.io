@page "/finch"
@inject ILocalStorageService LocalStorage
@implements IDisposable

<PageTitle>Finch Self-Care</PageTitle>

<div class="finch-container">
    <h1 class="mb-4 text-center">🐦✨ Your Daily Adventure ✨🐦</h1>

    @if (dailyList == null)
    {
        <div class="text-center"><div class="spinner-border"></div></div>
    }
    else
    {
        @if (!dailyList.Goals.Any() && !dailyList.Routines.Any())
        {
            <div class="text-center">
                <p class="text-muted">Ready for a new day?</p>
                <button class="btn btn-generate-goals" @onclick="GenerateNewGoals">Let's Go!</button>
            </div>
        }
        else
        {
            <!-- Goals Progress Bar -->
            <div class="mb-4 px-3">
                <h5 class="progress-title">Discovery Goals</h5>
                <div class="progress" style="height: 25px;">
                    <div class="progress-bar" role="progressbar" style="width: @GoalsProgressPercent%; background-color: #a2d2ff;">
                        @($"{GoalsProgressPercent:F0}%")
                    </div>
                </div>
            </div>

            <!-- Kanban-style Horizontal Scroll for Goals -->
            <div class="kanban-container">
                @{ int colorIndex = 0; }
                @foreach (var area in selfCareAreas)
                {
                    var cardColor = pastelColors[colorIndex % pastelColors.Count];
                    colorIndex++;
                    <div class="kanban-card">
                        <div class="card h-100 shadow-sm" style="background-color: @cardColor;">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">@GetEmojiForArea(area.Key) @area.Key</h5>
                                <button class="btn btn-sm btn-add-goal" @onclick="() => OpenAddGoalModal(area.Key)">+</button>
                            </div>
                            <div class="card-body">
                                <ul class="list-group list-group-flush">
                                    @foreach (var goal in dailyList.Goals.Where(g => g.AreaName == area.Key && !g.IsCompleted))
                                    {
                                        <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" @onclick="() => ToggleTaskCompletion(goal)">
                                            <span>@goal.Text</span>
                                            <button class="btn btn-sm btn-remove-goal ms-2" @onclick="() => RemoveGoal(goal)" @onclick:stopPropagation="true">x</button>
                                        </li>
                                    }
                                    @if (!dailyList.Goals.Any(g => g.AreaName == area.Key && !g.IsCompleted))
                                    {
                                        <p class="text-muted text-center mt-3">You're amazing! ✨</p>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Daily Routines Section -->
            <div class="mt-4 px-3">
                <h4 class="mb-3">Daily Routines</h4>
                <div class="progress mb-3" style="height: 25px;">
                    <div class="progress-bar" role="progressbar" style="width: @RoutinesProgressPercent%; background-color: #bde0fe;">
                        @($"{RoutinesProgressPercent:F0}%")
                    </div>
                </div>
                <ul class="list-group">
                    @foreach (var routine in dailyList.Routines.Where(r => !r.IsCompleted))
                    {
                        <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" @onclick="() => ToggleTaskCompletion(routine)">
                            <span>@routine.Text</span>
                            <button class="btn btn-sm btn-remove-goal ms-2" @onclick="() => RemoveRoutine(routine)" @onclick:stopPropagation="true">x</button>
                        </li>
                    }
                </ul>
            </div>

            <!-- Completed Goals Section -->
            <div class="mt-5 px-3">
                <h4 class="mb-3">Journey Complete!</h4>
                @if (completionMessage != null)
                {
                    <div class="completion-message">@completionMessage</div>
                }
                @if (AllTasks.Any(g => g.IsCompleted))
                {
                    <ul class="list-group">
                        @foreach (var task in AllTasks.Where(g => g.IsCompleted).OrderBy(g => g.AreaName))
                        {
                            <li class="list-group-item list-group-item-light list-group-item-action" @onclick="() => ToggleTaskCompletion(task)">
                                <span class="text-decoration-line-through text-muted">
                                    @GetEmojiForArea(task.AreaName) @task.Text
                                </span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">Ready to start your journey?</p>
                }
            </div>

            <!-- Action Buttons -->
            <div class="text-center mt-4 mb-4">
                <button class="btn btn-reroll" @onclick="GenerateNewGoals">New Adventure!</button>
                <button class="btn btn-secondary ms-2" @onclick="ResetRoutines">Reset Routines</button>
            </div>
        }
    }
</div>

<!-- Add Goal Modal -->
@if (isModalOpen)
{
    <div class="modal fade show" style="display:block;" tabindex="-1">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add a Goal to "@selectedAreaForAdding"</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddGoalModal"></button>
                </div>
                <div class="modal-body">
                    <ul class="list-group">
                        @foreach (var goalText in selfCareAreas[selectedAreaForAdding])
                        {
                            <li class="list-group-item list-group-item-action" @onclick="() => AddGoalManually(goalText, selectedAreaForAdding)">
                                @goalText
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}


<style>
    .finch-container {
        background: linear-gradient(180deg, #e2eafc 0%, #f0f4fc 100%);
        min-height: 100vh;
    }

    .progress-title {
        font-weight: 600;
        color: #5a67d8;
    }

    .progress-bar {
        font-weight: bold;
        color: #fff;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
    }

    .kanban-container { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; gap: 1rem; padding: 1rem; }
    .kanban-card { flex: 0 0 80%; scroll-snap-align: center; max-width: 350px; }
    .kanban-container::-webkit-scrollbar { display: none; }
    .kanban-container { -ms-overflow-style: none; scrollbar-width: none; }

    .kanban-card .card {
        border: none;
        border-radius: 15px;
    }
    .kanban-card .card-header {
        border-bottom: none;
        background-color: transparent;
        font-weight: bold;
        color: #4a5568;
    }
    .kanban-card .list-group-item {
        background-color: rgba(255,255,255,0.6);
        border-radius: 10px;
        margin-bottom: 0.5rem;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .btn-add-goal {
        background-color: rgba(255,255,255,0.5);
        border: 1px solid rgba(0,0,0,0.1);
        border-radius: 50%;
        font-weight: bold;
        color: #4a5568;
    }
    .btn-remove-goal {
        background-color: transparent;
        border: none;
        color: #cbd5e0;
    }
    .btn-remove-goal:hover {
        color: #e53e3e;
    }

    .btn-generate-goals, .btn-reroll {
        background-color: #667eea;
        color: white;
        font-weight: bold;
        border-radius: 20px;
        padding: 10px 25px;
        border: none;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .list-group-item-action { cursor: pointer; }

    .completion-message {
        text-align: center;
        font-weight: bold;
        color: #48bb78;
        animation: fadeInOut 2s ease-in-out;
    }

    @@keyframes fadeInOut {
        0% { opacity: 0; transform: translateY(10px); }
        25% { opacity: 1; transform: translateY(0); }
        75% { opacity: 1; }
        100% { opacity: 0; }
    }
</style>

@code {
    private DailyList? dailyList;
    private bool isModalOpen = false;
    private string selectedAreaForAdding = "";
    private string? completionMessage;
    private Timer? completionMessageTimer;

    private readonly List<string> pastelColors = new() { "#ffc09f", "#ffee93", "#a0ced9", "#adf7b6", "#fcf5c7" };

    private List<DailyTask> AllTasks => (dailyList?.Goals ?? new List<DailyTask>()).Concat(dailyList?.Routines ?? new List<DailyTask>()).ToList();

    private double GoalsProgressPercent
    {
        get
        {
            if (dailyList == null || !dailyList.Goals.Any()) return 0;
            var completedCount = dailyList.Goals.Count(g => g.IsCompleted);
            return (double)completedCount / dailyList.Goals.Count * 100;
        }
    }

    private double RoutinesProgressPercent
    {
        get
        {
            if (dailyList == null || !dailyList.Routines.Any()) return 0;
            var completedCount = dailyList.Routines.Count(g => g.IsCompleted);
            return (double)completedCount / dailyList.Routines.Count * 100;
        }
    }

    private readonly List<string> fixedRoutineTasks = new()
    {
        "AM Brush", "AM Wash Face", "AM Minoxidil", "AM Shower", "PM Brush", "PM Floss", "PM Minoxidil", "PM Tretinoin", "PM Clear Room of Dishes"
    };

    private readonly Dictionary<string, List<string>> selfCareAreas = new()
    {
        { "Sleep", new List<string> { "Go to bed by 11 PM", "Read a book before bed", "No screens 30 mins before sleep", "Drink chamomile tea", "Tidy up bedroom", "Set out clothes for tomorrow" } },
        { "Nutrition", new List<string> { "Eat a piece of fruit", "Drink a glass of water", "Eat a vegetable with lunch", "Avoid sugary snacks", "Plan tomorrow's meals", "Try a new healthy recipe" } },
        { "Movement", new List<string> { "Go for a 10-minute walk", "Do 5 minutes of stretching", "Stand up every hour", "Do a quick workout video", "Take the stairs" } },
        { "Mindfulness", new List<string> { "Meditate for 5 minutes", "Write down 3 things you're grateful for", "Listen to a calming song", "Do a breathing exercise", "Spend 5 minutes in nature" } },
        { "Chores", new List<string> { "Clear one surface (desk, counter)", "Wash the dishes", "Take out the trash", "Spend 15 minutes tidying up", "Start a load of laundry" } }
    };

    private string GetEmojiForArea(string areaName)
    {
        return areaName switch
        {
            "Sleep" => "😴",
            "Nutrition" => "🍎",
            "Movement" => "🏃",
            "Mindfulness" => "🧘",
            "Chores" => "🧹",
            "Routine" => "☀️",
            _ => "✨"
        };
    }

    protected override async Task OnInitializedAsync()
    {
        dailyList = await LocalStorage.GetItemAsync<DailyList>("finchDailyList");

        if (dailyList == null || dailyList.DateGenerated.Date != DateTime.Today)
        {
            await InitializeNewDay();
        }
    }

    private async Task InitializeNewDay()
    {
        dailyList = new DailyList { DateGenerated = DateTime.Today };
        dailyList.Routines.Clear();
        foreach (var taskText in fixedRoutineTasks)
        {
            dailyList.Routines.Add(new DailyTask { Text = taskText, AreaName = "Routine" });
        }
        await SaveProgress();
    }

    private async Task ResetRoutines()
    {
        if (dailyList == null) return;

        dailyList.Routines.Clear();
        foreach (var taskText in fixedRoutineTasks)
        {
            dailyList.Routines.Add(new DailyTask { Text = taskText, AreaName = "Routine" });
        }
        await SaveProgress();
    }

    private async Task GenerateNewGoals()
    {
        if (dailyList == null) return;
        dailyList.Goals.Clear();
        var random = new Random();

        foreach (var area in selfCareAreas)
        {
            var randomGoals = area.Value.OrderBy(x => random.Next()).Take(2).ToList();
            foreach (var goalText in randomGoals)
            {
                dailyList.Goals.Add(new DailyTask { Text = goalText, AreaName = area.Key });
            }
        }

        await SaveProgress();
    }

    private async Task ToggleTaskCompletion(DailyTask task)
    {
        task.IsCompleted = !task.IsCompleted;
        if (task.IsCompleted)
        {
            ShowCompletionMessage();
        }
        await SaveProgress();
    }

    private void ShowCompletionMessage()
    {
        var messages = new[] { "Great job!", "You're awesome!", "Nice one!", "Way to go!", "Fantastic!" };
        completionMessage = messages[new Random().Next(messages.Length)];
        
        completionMessageTimer?.Dispose();
        completionMessageTimer = new Timer(_ =>
        {
            completionMessage = null;
            InvokeAsync(StateHasChanged);
        }, null, 2000, Timeout.Infinite);
    }
    
    private async Task RemoveGoal(DailyTask goalToRemove)
    {
        dailyList?.Goals.Remove(goalToRemove);
        await SaveProgress();
    }

    private async Task RemoveRoutine(DailyTask routineToRemove)
    {
        dailyList?.Routines.Remove(routineToRemove);
        await SaveProgress();
    }

    private void OpenAddGoalModal(string areaName)
    {
        selectedAreaForAdding = areaName;
        isModalOpen = true;
    }

    private void CloseAddGoalModal()
    {
        isModalOpen = false;
    }

    private async Task AddGoalManually(string goalText, string areaName)
    {
        if (dailyList != null && !AllTasks.Any(g => g.Text == goalText))
        {
            dailyList.Goals.Add(new DailyTask { Text = goalText, AreaName = areaName });
            await SaveProgress();
        }
        CloseAddGoalModal();
    }

    private async Task SaveProgress()
    {
        if (dailyList != null)
        {
            await LocalStorage.SetItemAsync("finchDailyList", dailyList);
        }
    }

    public void Dispose()
    {
        completionMessageTimer?.Dispose();
    }
}
